import streamlit as st
import pandas as pd
import joblib

model = joblib.load("SVM.pkl")

st.title("Student Placement Predictor")

st.write("Enter student details to predict placement status")

study_hours = st.number_input("Study Hours", min_value=0, max_value=24)
attendance = st.number_input("Attendance (%)", min_value=0, max_value=100)
sleep_hours = st.number_input("Sleep Hours", min_value=0, max_value=24)
internet_usage = st.number_input("Internet Usage (hours)", min_value=0)
assignments_completed = st.number_input("Assignments Completed", min_value=0)
previous_score = st.number_input("Previous Score", min_value=0, max_value=100)

#creates a button and says if the button is clicked what happens
if st.button("Predict Placement"):

    #creates a dataframe with the students info
    #takes the values that the person entered and formats it like the training data
    new_data = pd.DataFrame(
        [[study_hours,
          attendance,
          sleep_hours,
          internet_usage,
          assignments_completed,
          previous_score]],
        columns=['study_hours',
                 'attendance',
                 'sleep_hours',
                 'internet_usage',
                 'assignments_completed',
                 'previous_score']
    )
#sends the data to the trained SVM model
    prediction = model.predict(new_data)

    if prediction[0] == "Placed":
        st.success("Student is likely to be Placed")
    else:
        st.error("Student is likely to be Not Placed")
